---
interface NavItem {
  label: string;
  href: string;
}

interface Props {
  copyright: string;
  nav: NavItem[];
}

const { copyright, nav } = Astro.props;
---

<footer class="bg-gray-900 text-gray-400 py-10">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <nav class="flex gap-6">
        {nav.map((item) => (
          <a href={item.href} class="hover:text-white transition-colors text-sm">
            {item.label}
          </a>
        ))}
      </nav>
      <p class="text-sm">{copyright}</p>
    </div>
  </div>
</footer>
