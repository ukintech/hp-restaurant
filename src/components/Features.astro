---
interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  heading: string;
  items: Feature[];
}

const { heading, items } = Astro.props;
---

<section class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-14">{heading}</h2>
    <div class="grid md:grid-cols-3 gap-8">
      {items.map((item) => (
        <div class="bg-white rounded-xl p-8 shadow-sm hover:shadow-md transition-shadow text-center">
          <div class="text-4xl mb-4">{item.icon}</div>
          <h3 class="text-xl font-bold mb-3">{item.title}</h3>
          <p class="text-gray-600 leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
