---
interface BusinessHour {
  days: string;
  hours: string;
}

interface Props {
  heading: string;
  address: string;
  tel?: string;
  businessHours: BusinessHour[];
  closedDay: string;
  mapEmbedUrl?: string;
}

const { heading, address, tel, businessHours, closedDay, mapEmbedUrl } = Astro.props;
---

<section class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-14">{heading}</h2>
    <div class="grid md:grid-cols-2 gap-12">
      <div class="space-y-6">
        <div>
          <h3 class="font-bold text-lg mb-2 text-primary-700">所在地</h3>
          <p class="text-gray-700">{address}</p>
        </div>
        {tel && (
          <div>
            <h3 class="font-bold text-lg mb-2 text-primary-700">電話番号</h3>
            <p class="text-gray-700">{tel}</p>
          </div>
        )}
        <div>
          <h3 class="font-bold text-lg mb-2 text-primary-700">営業時間</h3>
          <ul class="space-y-1">
            {businessHours.map((bh) => (
              <li class="text-gray-700">
                <span class="font-bold">{bh.days}</span>
                <span class="ml-2">{bh.hours}</span>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-bold text-lg mb-2 text-primary-700">定休日</h3>
          <p class="text-gray-700">{closedDay}</p>
        </div>
      </div>
      <div>
        {mapEmbedUrl ? (
          <iframe
            src={mapEmbedUrl}
            width="100%"
            height="350"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="rounded-xl shadow-sm"
          ></iframe>
        ) : (
          <div class="bg-gray-200 rounded-xl h-[350px] flex items-center justify-center text-gray-500">
            Google Map
          </div>
        )}
      </div>
    </div>
  </div>
</section>
