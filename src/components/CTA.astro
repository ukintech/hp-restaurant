---
interface Props {
  heading: string;
  description: string;
  button: {
    label: string;
    href: string;
  };
}

const { heading, description, button } = Astro.props;
---

<section class="py-20 bg-primary-700 text-white">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-2xl md:text-3xl font-bold mb-4">{heading}</h2>
    <p class="text-primary-100 mb-10 text-lg">{description}</p>
    <a
      href={button.href}
      class="inline-block bg-white text-primary-700 font-bold px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors text-lg"
    >
      {button.label}
    </a>
  </div>
</section>
