---
interface Stat {
  label: string;
  value: string;
}

interface Props {
  heading: string;
  description: string;
  stats: Stat[];
}

const { heading, description, stats } = Astro.props;
---

<section class="py-20">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-8">{heading}</h2>
    <p class="text-gray-600 text-center max-w-3xl mx-auto mb-12 leading-relaxed text-lg">
      {description}
    </p>
    <div class="grid grid-cols-3 gap-6 max-w-2xl mx-auto">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-primary-600 mb-2">{stat.value}</div>
          <div class="text-sm text-gray-500">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
